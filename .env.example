# Copy to .env locally; set these as environment variables on Render.
NODE_ENV=production
PORT=3000

# MongoDB Atlas connection string
MONGO_URI=mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/?retryWrites=true&w=majority
MONGO_DB=blueprint
SHOW_ID=LEX26

# Required in production — the server refuses to boot without them.
ADMIN_USER=
ADMIN_PASS=
SESSION_SECRET=

# Origin allowed to open a socket, e.g. https://your-app.onrender.com
PUBLIC_ORIGIN=

# Retention for behavioural events. Must match your privacy policy.
ACTIVITY_RETENTION_DAYS=730

# Optional webhook for new-enquiry notifications (Zapier/Make/Slack/CRM inbound)
NOTIFY_WEBHOOK=
